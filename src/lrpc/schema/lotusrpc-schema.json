{
  "$defs": {
    "cppid": {
      "type": "string",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
      "description": "A valid C++ identifier"
    },
    "uint8": {
      "type": "integer",
      "description": "Unsigned 8-bit integer (0-255)",
      "minimum": 0,
      "maximum": 255
    },
    "int8": {
      "type": "integer",
      "description": "Signed 8-bit integer (-128 to 127)",
      "minimum": -128,
      "maximum": 127
    },
    "uint16": {
      "type": "integer",
      "description": "Unsigned 16-bit integer (0-65535)",
      "minimum": 0,
      "maximum": 65535
    },
    "int16": {
      "type": "integer",
      "description": "Signed 16-bit integer (-32768 to 32767)",
      "minimum": -32768,
      "maximum": 32767
    },
    "uint32": {
      "type": "integer",
      "description": "Unsigned 32-bit integer (0-4294967295)",
      "minimum": 0,
      "maximum": 4294967295
    },
    "int32": {
      "type": "integer",
      "description": "Signed 32-bit integer (-2147483648 to 2147483647)",
      "minimum": -2147483648,
      "maximum": 2147483647
    },
    "uint64": {
      "type": "integer",
      "description": "Unsigned 64-bit integer (0-18446744073709551615)",
      "minimum": 0,
      "maximum": 18446744073709551615
    },
    "int64": {
      "type": "integer",
      "description": "Signed 64-bit integer (-9223372036854775808 to 9223372036854775807)",
      "minimum": -9223372036854775808,
      "maximum": 9223372036854775807
    },
    "bytearray_hex_string": {
      "type": "string",
      "description": "Hex string for bytearray constants (compatible with Python bytes.fromhex)",
      "pattern": "^\\s*([0-9a-fA-F]{2}\\s*)*$"
    },
    "service_id": {
      "type": "integer",
      "description": "Service ID (0-254)",
      "minimum": 0,
      "maximum": 254
    },
    "enum_field": {
      "type": "object",
      "description": "Enumeration field consisting of a name and an optional ID",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/cppid"
        },
        "id": {
          "$ref": "#/$defs/uint8"
        }
      }
    },
    "enum_decl": {
      "type": "object",
      "description": "An enum declaration",
      "required": [
        "name",
        "fields"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/cppid"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "description": "List of enum fields or names. IDs are assigned automatically if not specified",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/cppid"
              },
              {
                "$ref": "#/$defs/enum_field"
              }
            ]
          }
        },
        "external": {
          "type": "string",
          "description": "Header file containing the definition of the enum"
        },
        "external_namespace": {
          "type": "string",
          "description": "Namespace in which the external enum is declared"
        }
      }
    },
    "var_decl": {
      "type": "object",
      "description": "Variable declaration with name and type. Specifying an integer value (>1) for 'count' makes it an array of the specified type. Specifiying a '?' makes it an optional of the specified type. Type can be any of the C++ standard types (u)intx_t, float, double or bool. It can also be 'string_x' for a fixed size string or 'string' for a variable size string. Finally, it can be any custom struct or enum defined in the specification",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/cppid"
        },
        "type": {
          "oneOf": [
            {
              "enum": [
                "uint8_t",
                "int8_t",
                "uint16_t",
                "int16_t",
                "uint32_t",
                "int32_t",
                "uint64_t",
                "int64_t",
                "float",
                "double",
                "bool",
                "string",
                "bytearray"
              ]
            },
            {
              "type": "string",
              "pattern": "^string_(0*[1-9][0-9]*)$"
            },
            {
              "type": "string",
              "pattern": "^@[a-zA-Z_][a-zA-Z0-9_]*$"
            }
          ]
        },
        "count": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "const": "?"
            }
          ]
        }
      }
    },
    "struct_decl": {
      "type": "object",
      "description": "A struct declaration",
      "required": [
        "name",
        "fields"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/cppid"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/var_decl"
          },
          "description": "List of struct fields"
        },
        "external": {
          "type": "string",
          "description": "Header file containing the definition of the struct"
        },
        "external_namespace": {
          "type": "string",
          "description": "Namespace in which the external struct is declared"
        }
      }
    },
    "const_decl": {
      "type": "object",
      "description": "A constant declaration",
      "required": [ "name", "value" ],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/cppid" },
        "value": { },
        "cppType": {
          "enum": [ "uint8_t", "int8_t", "uint16_t", "int16_t", "uint32_t", "int32_t", "uint64_t", "int64_t", "float", "double", "bool", "string", "bytearray" ]
        }
      },
      "allOf": [
        { "if": { "not": { "required": [ "cppType" ] } }, "then": { "properties": { "value": { "oneOf": [ { "type": "string" }, { "type": "number" }, { "type": "boolean" } ] } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "uint8_t" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/uint8" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "int8_t" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/int8" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "uint16_t" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/uint16" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "int16_t" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/int16" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "uint32_t" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/uint32" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "int32_t" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/int32" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "uint64_t" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/uint64" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "int64_t" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/int64" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "string" } } }, "then": { "properties": { "value": { "oneOf": [ { "type": "string" }, { "type": "number" }, { "type": "boolean" } ] } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "bool" } } }, "then": { "properties": { "value": { "type": "boolean" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "float" } } }, "then": { "properties": { "value": { "type": "number" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "double" } } }, "then": { "properties": { "value": { "type": "number" } } } },
        { "if": { "required": [ "cppType" ], "properties": { "cppType": { "const": "bytearray" } } }, "then": { "properties": { "value": { "$ref": "#/$defs/bytearray_hex_string" } } } }
      ]
    },
    "function_decl": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/cppid"
        },
        "id": {
          "$ref": "#/$defs/uint8"
        },
        "params": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/var_decl"
          },
          "description": "List of function parameters"
        },
        "returns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/var_decl"
          },
          "description": "List of function returns"
        }
      }
    },
    "stream_decl": {
      "type": "object",
      "required": [
        "name",
        "origin"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/cppid"
        },
        "id": {
          "$ref": "#/$defs/uint8"
        },
        "origin": {
          "enum": [
            "server",
            "client"
          ]
        },
        "finite": {
          "type": "boolean",
          "description": "Generate additional code to notify the receiver of the last message in a stream. Default false"
        },
        "params": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/var_decl"
          },
          "description": "List of stream parameters"
        }
      }
    },
    "service_decl": {
      "type": "object",
      "required": [
        "name"
      ],
      "anyOf": [
        {
          "required": [
            "functions"
          ]
        },
        {
          "required": [
            "streams"
          ]
        }
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/cppid"
        },
        "id": {
          "$ref": "#/$defs/service_id"
        },
        "functions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/function_decl"
          },
          "description": "List of functions in the service (max 256 functions and streams combined)"
        },
        "streams": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/stream_decl"
          },
          "description": "List of streams in the service (max 256 functions and streams combined)"
        },
        "functions_before_streams": {
          "type": "boolean",
          "description": "Indicate if LRPC should start automatic assignment if IDs with functions or streams. Default is the order of specification in the definition file"
        }
      }
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lotus RPC",
  "description": "JSON Schema for Lotus RPC, a RPC code generation tool",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "name",
    "services"
  ],
  "properties": {
    "name": {
      "$ref": "#/$defs/cppid",
      "description": "Name of the RPC"
    },
    "version": {
      "type": "string",
      "description": "Version of the definition file"
    },
    "definition_hash_length": {
      "type": "integer",
      "minimum": 0,
      "maximum": 64,
      "description": "Length of definition hash to include in generated code"
    },
    "namespace": {
      "$ref": "#/$defs/cppid",
      "description": "C++ namespace to be generate code in"
    },
    "rx_buffer_size": {
      "type": "integer",
      "minimum": 1,
      "description": "Size of the server side receive buffer in bytes"
    },
    "tx_buffer_size": {
      "type": "integer",
      "minimum": 1,
      "description": "Size of the server side transmit buffer in bytes"
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/service_decl"
      },
      "description": "A list of services (max 256 services)"
    },
    "structs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/struct_decl"
      },
      "description": "A list of custom structs"
    },
    "enums": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/enum_decl"
      },
      "description": "A list of custom enums"
    },
    "constants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/const_decl"
      },
      "description": "A list of custom constants"
    }
  }
}